pipeline {
    agent {
        kubernetes {
            label 'sample-app'
            yaml """
apiVersion: v1
kind: Pod
metadata:
  labels:
    component: ci
spec:
  containers:
  - name: gcloud
    image: google/cloud-sdk:latest
    command:
    - cat
    tty: true
"""
        }
    }

    tools {
        maven 'maven'
    }

    environment {
        REPO_PATH = credentials("repo_path")
        APP_NAME = "binarycalculatorwebapp"
        IMAGE_TAG = "${REPO_PATH}/${APP_NAME}"
        CLUSTER = credentials("cluster_name")
        CLUSTER_ZONE = credentials("cluster_zone")
    }

    stages {

        stage('test') {
            steps {
                sh 'mvn clean test -f ./BinaryCalculatorWebapp/pom.xml'
            }
        }

        stage('build') {
            steps {
                sh 'mvn clean package -DskipTests -f ./BinaryCalculatorWebapp/pom.xml'
            }
        }

        stage('containerize') {
            steps {
                withCredentials([
                    string(credentialsId: 'project_id', variable: 'PROJECT_ID'),
                    file(credentialsId: 'service_account', variable: 'SERVICE_ACCOUNT')
                ]) {
                    container('gcloud') {
                        dir('BinaryCalculatorWebapp') {
                            sh 'gcloud auth activate-service-account --key-file=$SERVICE_ACCOUNT'
                            sh 'gcloud config set project $PROJECT_ID'
                            sh 'gcloud builds submit -t $IMAGE_TAG --quiet'
                        }
                    }
                }
            }
        }

        stage('deployment') {
            steps {
                withCredentials([
                    string(credentialsId: 'project_id', variable: 'PROJECT_ID'),
                    file(credentialsId: 'service_account', variable: 'SERVICE_ACCOUNT')
                ]) {
                    container('gcloud') {
                        dir('BinaryCalculatorWebapp') {
                            sh 'gcloud auth activate-service-account --key-file=$SERVICE_ACCOUNT'
                            sh 'gcloud config set project $PROJECT_ID'
                            sh 'gcloud container clusters get-credentials $CLUSTER --zone=$CLUSTER_ZONE'

                            script {
                                try {
                                    sh 'kubectl delete deployment binarycalculator-deployment'
                                } catch (Exception e) {
                                    echo "No previous deployment"
                                }
                            }

                            sh 'kubectl create deployment binarycalculator-deployment --image=$IMAGE_TAG --port=8080'
                        }
                    }
                }
            }
        }

        stage('service') {
            steps {
                withCredentials([
                    string(credentialsId: 'project_id', variable: 'PROJECT_ID'),
                    file(credentialsId: 'service_account', variable: 'SERVICE_ACCOUNT')
                ]) {
                    container('gcloud') {
                        dir('BinaryCalculatorWebapp') {
                            sh 'gcloud auth activate-service-account --key-file=$SERVICE_ACCOUNT'
                            sh 'gcloud config set project $PROJECT_ID'
                            sh 'gcloud container clusters get-credentials $CLUSTER --zone=$CLUSTER_ZONE'

                            script {
                                try {
                                    sh 'kubectl expose deployment binarycalculator-deployment --type=LoadBalancer --name=binarycalculator-service'
                                } catch (Exception e) {
                                    echo "Service already exists"
                                }
                            }

                            sh "kubectl get service binarycalculator-service"
                        }
                    }
                }
            }
        }
    }
}
